@using EntityLayer.Concrete
@model List<Project>
@{
    ViewData["Title"] = "Projelerimiz";
    ViewData["MetaDescription"] = "Usta Yapı olarak bugüne kadar tamamladığımız lüks banyo, mutfak yenileme ve komple anahtar teslim inşaat projelerimizi inceleyin.";
    ViewData["MetaKeywords"] = "inşaat projeleri, tamamlanan projeler, mutfak tadilatı, banyo yenileme, samsun dekorasyon projeleri";

    // Admin yetkisi kontrolü
    bool isAdmin = User.Identity.IsAuthenticated && User.IsInRole("Admin");
}

@section Styles {
    <style>
        .page-header {
            background: linear-gradient(rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.7)), url('https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            height: 40vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
            margin-top: 70px;
        }

        .projects-cta {
            background-color: var(--dark);
            color: white;
            text-align: center;
            padding: 80px 0;
        }

            .projects-cta h3 {
                font-weight: 700;
                margin-bottom: 15px;
            }

        /* Admin Butonları İçin Stil */
        .admin-actions {
            position: absolute;
            top: 15px;
            right: 15px;
            z-index: 10;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .portfolio-wrap:hover .admin-actions {
            opacity: 1;
        }

        /* Lightbox Carousel İyileştirmeleri */
        #lightboxModal .modal-content {
            background: transparent;
            border: none;
        }

        #lightboxModal .btn-close {
            filter: invert(1) grayscale(100%) brightness(200%);
            opacity: 0.8;
        }
    </style>
}

<section class="page-header">
    <div class="container" data-aos="fade-up">
        <h1 class="display-3 fw-bold">Projelerimiz</h1>
        <p class="lead">İmzamızı attığımız, gurur duyduğumuz işler.</p>

        @if (isAdmin)
        {
            <button class="btn btn-warning btn-lg mt-3 fw-bold shadow-lg" data-bs-toggle="modal" data-bs-target="#addProjectModal">
                <i class="fas fa-plus me-2"></i>Yeni Proje Ekle
            </button>
        }
    </div>
</section>

<section class="py-5">
    <div class="container">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm" role="alert">
                <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <div class="row" data-aos="fade-up" data-aos-delay="100">
                <div class="col-lg-12 d-flex justify-content-center">
                    <ul class="portfolio-filters">
                        <li data-filter="*" class="filter-active">Tümü</li>
                        <li data-filter=".filter-tadilat">Tadilat & Dekorasyon</li>
                        <li data-filter=".filter-insaat">Kaba İnşaat</li>
                        <li data-filter=".filter-banyo">Banyo & Mutfak</li>
                    </ul>
                </div>
            </div>

            <div class="row portfolio-container" data-aos="fade-up" data-aos-delay="200">

                @foreach (var item in Model)
                {
                    var coverImg = item.ProjectImages?.FirstOrDefault(x => x.IsCover)?.ImageUrl ?? "https://via.placeholder.com/600x400?text=Gorsel+Yok";

                    var allImages = item.ProjectImages?.Select(x => x.ImageUrl).ToList() ?? new List<string>();
                    var imagesJson = System.Text.Json.JsonSerializer.Serialize(allImages);

                    var shortDesc = string.IsNullOrEmpty(item.Description) ? "" :
                    (item.Description.Length > 60 ? item.Description.Substring(0, 60) + "..." : item.Description);

                    <div class="col-lg-4 col-md-6 portfolio-item @item.Category">
                        <div class="portfolio-wrap">

                            @if (isAdmin)
                            {
                                <div class="admin-actions">
                                    <button class="btn btn-sm btn-primary shadow btn-edit-project" data-bs-toggle="modal" data-bs-target="#editProjectModal"
                                            data-id="@item.Id"
                                            data-title="@item.Title"
                                            data-category="@item.Category"
                                            data-desc="@item.Description"
                                            data-year="@item.Year">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <form asp-action="DeleteProject" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu projeyi silmek istediğinize emin misiniz?');">
                                        <button type="submit" class="btn btn-sm btn-danger shadow"><i class="fas fa-trash"></i></button>
                                    </form>
                                </div>
                            }

                            <img src="@coverImg" alt="@item.Title">
                            <div class="portfolio-info">
                                <h4 class="text-truncate" title="@item.Title">@item.Title</h4>
                                <p class="small text-white-50 mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@shortDesc</p>
                                <span class="badge bg-warning text-dark mt-1 mb-3">@item.Year</span>
                                <br />
                                <button class="btn btn-sm btn-outline-light rounded-pill px-3 btn-lightbox"
                                        data-images='@imagesJson'
                                        data-title="@item.Title"
                                        data-desc="@item.Description"
                                        data-year="@item.Year"
                                        data-category="@item.Category">
                                    <i class="fas fa-search-plus me-1"></i> Detaylı İncele
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="row" data-aos="fade-up">
                <div class="col-12 text-center py-5">
                    <i class="fas fa-folder-open fa-4x text-muted mb-3"></i>
                    <h3 class="text-muted fw-bold">Henüz Eklenmiş Proje Bulunmuyor</h3>
                    <p class="text-secondary">Şu an için gösterilecek bir proje kaydı yok.</p>
                    @if (isAdmin)
                    {
                        <p class="mt-3">Yukarıdaki <strong>"Yeni Proje Ekle"</strong> butonuna tıklayarak ilk projenizi oluşturabilirsiniz.</p>
                    }
                </div>
            </div>
        }
    </div>
</section>

<section class="projects-cta">
    <div class="container" data-aos="zoom-in">
        <h3>Sizin Projeniz Bir Sonraki Olsun</h3>
        <p class="text-white-50 mb-4">Ücretsiz keşif ve fiyatlandırma için hemen iletişime geçin.</p>
        <a href="https://wa.me/905000000000" class="btn btn-warning btn-lg fw-bold rounded-pill px-5">
            <i class="fab fa-whatsapp me-2"></i>WhatsApp'tan Yaz
        </a>
    </div>
</section>

<div class="modal fade" id="lightboxModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content bg-dark text-white border-0 shadow-lg">

            <div class="modal-header border-bottom border-secondary">
                <div class="d-flex flex-column">
                    <h4 class="modal-title fw-bold text-warning" id="lightboxTitle">Proje Başlığı</h4>
                    <span class="badge bg-secondary w-auto" id="lightboxCategory">Kategori</span>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-0">
                <div id="projectCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner bg-black" id="carouselInner">
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#projectCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#projectCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    </button>
                </div>

                <div class="p-4 bg-dark">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold m-0"><i class="fas fa-info-circle me-2 text-warning"></i>Proje Detayları</h5>
                        <span class="fs-5 text-muted" id="lightboxYear"><i class="far fa-calendar-alt me-1"></i> 2024</span>
                    </div>
                    <p class="text-light" id="lightboxDescription" style="line-height: 1.8; font-size: 1.1rem;">
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>

@if (isAdmin)
{
    <div class="modal fade" id="addProjectModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title"><i class="fas fa-plus me-2"></i>Yeni Proje Ekle</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="/Home/AddProject" method="post" enctype="multipart/form-data">
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label class="form-label">Proje Başlığı</label>
                                <input type="text" name="Title" class="form-control" required maxlength="200">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Yıl</label>
                                <input type="number" name="Year" class="form-control" value="@DateTime.Now.Year" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Kategori</label>
                                <select name="Category" class="form-select" required>
                                    <option value="">Seçiniz...</option>
                                    <option value="filter-tadilat">Tadilat & Dekorasyon</option>
                                    <option value="filter-insaat">Kaba İnşaat</option>
                                    <option value="filter-banyo">Banyo & Mutfak</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Proje Resmi (Kapak)</label>
                                <input type="file" name="CoverImage" class="form-control" accept="image/*" required>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Galeri Resimleri (Birden Fazla Seçebilirsiniz)</label>
                                <input type="file" name="GalleryImages" class="form-control" accept="image/*" multiple>
                                <small class="text-muted">Proje detaylarında gösterilecek ekstra fotoğraflar.</small>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Açıklama</label>
                                <textarea name="Description" class="form-control" rows="3"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-warning fw-bold">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editProjectModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-edit me-2"></i>Projeyi Düzenle</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="/Home/EditProject" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="Id" id="edit-id">
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label class="form-label">Proje Başlığı</label>
                                <input type="text" name="Title" id="edit-title" class="form-control" required maxlength="200">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Yıl</label>
                                <input type="number" name="Year" id="edit-year" class="form-control" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Kategori</label>
                                <select name="Category" id="edit-category" class="form-select" required>
                                    <option value="filter-tadilat">Tadilat & Dekorasyon</option>
                                    <option value="filter-insaat">Kaba İnşaat</option>
                                    <option value="filter-banyo">Banyo & Mutfak</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Yeni Resim (İsteğe Bağlı)</label>
                                <input type="file" name="CoverImage" class="form-control" accept="image/*">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Açıklama</label>
                                <textarea name="Description" id="edit-description" class="form-control" rows="3"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-primary fw-bold">Güncelle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // DOM yüklendiğinde Butonlara Event Listener Ekliyoruz (GÜVENLİ YÖNTEM)
        document.addEventListener("DOMContentLoaded", function() {

            // DÜZENLE BUTONLARI İÇİN
            document.querySelectorAll('.btn-edit-project').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.getElementById('edit-id').value = this.getAttribute('data-id');
                    document.getElementById('edit-title').value = this.getAttribute('data-title');
                    document.getElementById('edit-category').value = this.getAttribute('data-category');
                    document.getElementById('edit-year').value = this.getAttribute('data-year');

                    let desc = this.getAttribute('data-desc');
                    document.getElementById('edit-description').value = desc ? desc.replace(/<br>/g, '\n') : '';
                });
            });

            // LİGHTBOX BUTONLARI İÇİN
            document.querySelectorAll('.btn-lightbox').forEach(btn => {
                btn.addEventListener('click', function() {
                    const images = JSON.parse(this.getAttribute('data-images') || '[]');
                    const title = this.getAttribute('data-title');
                    let description = this.getAttribute('data-desc');
                    const year = this.getAttribute('data-year');
                    const category = this.getAttribute('data-category');

                    // Açıklamadaki \n (enter) karakterlerini HTML'in anlayacağı <br> etiketine çevir
                    if(description) {
                        description = description.replace(/\r\n|\n/g, '<br>');
                    }

                    openLightbox(images, title, description, year, category);
                });
            });

        });

        // AOS Animasyonları vs. ve Filtreleme kodu
        const filters = document.querySelectorAll('.portfolio-filters li');
        const items = document.querySelectorAll('.portfolio-item');

        filters.forEach(filter => {
            filter.addEventListener('click', function () {
                filters.forEach(f => f.classList.remove('filter-active'));
                this.classList.add('filter-active');

                const category = this.getAttribute('data-filter');

                items.forEach(item => {
                    item.style.display = 'none';
                    item.classList.remove('aos-animate');

                    if (category === '*' || item.classList.contains(category.substring(1))) {
                        item.style.display = 'block';
                        setTimeout(() => item.classList.add('aos-animate'), 50);
                    }
                });
            });
        });

        // LİGHTBOX'I DOLDURAN VE AÇAN FONKSİYON
        function openLightbox(images, title, description, year, category) {

            document.getElementById('lightboxTitle').innerText = title;
            document.getElementById('lightboxDescription').innerHTML = description ? description : "Bu proje için bir açıklama girilmemiş.";
            document.getElementById('lightboxYear').innerHTML = `<i class="far fa-calendar-alt me-1"></i> ${year}`;

            // Kategoriyi güzel bir isimle göster
            let catName = "Diğer";
            if(category && category.includes("tadilat")) catName = "Tadilat & Dekorasyon";
            else if(category && category.includes("insaat")) catName = "Kaba İnşaat";
            else if(category && category.includes("banyo")) catName = "Banyo & Mutfak";
            else catName = category;
            document.getElementById('lightboxCategory').innerText = catName;

            const carouselInner = document.getElementById('carouselInner');
            carouselInner.innerHTML = '';

            if(!images || images.length === 0) {
                carouselInner.innerHTML = `<div class="carousel-item active text-center p-5"><h5 class="text-muted">Görsel bulunamadı.</h5></div>`;
            } else {
                images.forEach((imgUrl, index) => {
                    const isActive = index === 0 ? 'active' : '';
                    const itemHtml = `
                        <div class="carousel-item ${isActive}">
                            <img src="${imgUrl}" class="d-block w-100" style="height: 60vh; object-fit: contain;" alt="Proje Görseli">
                        </div>
                    `;
                    carouselInner.innerHTML += itemHtml;
                });
            }

            var myModal = new bootstrap.Modal(document.getElementById('lightboxModal'));
            myModal.show();
        }

        // Hata/Başarı Mesajları için Oto-Gizleme
        setTimeout(function () {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function (alert) {
                alert.style.transition = "opacity 0.6s ease";
                alert.style.opacity = "0";
                setTimeout(function () { alert.remove(); }, 600);
            });
        }, 5000);
    </script>
}
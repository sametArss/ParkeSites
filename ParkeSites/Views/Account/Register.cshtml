@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kayıt Ol | Usta Yapı</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #FFC107;
            --dark: #1a1a1a;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
        }

        .register-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.2);
        }

        .logo {
            font-weight: 700;
            font-size: 1.5rem;
            margin-bottom: 5px;
        }

            .logo span {
                color: var(--primary);
            }

        .register-title {
            font-weight: 700;
            margin-bottom: 20px;
            color: var(--dark);
        }

        .form-control {
            border-radius: 50px;
            padding: 12px 20px;
        }

            .form-control:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 0.2rem rgba(255, 193, 7, 0.25);
            }

        .btn-register {
            background: var(--primary);
            border: none;
            border-radius: 50px;
            padding: 12px;
            font-weight: 600;
            transition: 0.3s;
            color: var(--dark);
        }

            .btn-register:hover {
                background: #fff;
                color: var(--primary);
                border: 1px solid var(--primary);
            }

        .form-icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #999;
            z-index: 10;
        }

        .input-group-custom {
            position: relative;
        }

            .input-group-custom input {
                padding-left: 45px;
            }

        .extra-links a {
            text-decoration: none;
            color: var(--dark);
            font-size: 0.95rem;
            font-weight: 500;
            transition: 0.3s;
        }

            .extra-links a:hover {
                color: var(--primary);
            }

        .alert {
            border-radius: 10px;
            font-size: 0.9rem;
            text-align: center;
        }
    </style>
</head>

<body>

    <div class="register-card">
        <div class="text-center mb-4">
            <div class="logo">
                <i class="fas fa-hammer"></i> USTA<span>YAPI</span>
            </div>
            <h4 class="register-title">Yeni Kayıt Oluştur</h4>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <form asp-action="Register" method="post">

            <div class="mb-3 input-group-custom">
                <i class="fas fa-user form-icon"></i>
                <input type="text" class="form-control" name="FullName" placeholder="Ad Soyad" required>
            </div>

            <div class="mb-3 input-group-custom">
                <i class="fas fa-envelope form-icon"></i>
                <input type="email" class="form-control" name="Email" placeholder="E-posta adresi" required>
            </div>

            <div class="mb-4 input-group-custom">
                <i class="fas fa-lock form-icon"></i>
                <input type="password" class="form-control" name="Password" placeholder="Şifre" required>
            </div>

            <button type="submit" class="btn btn-register w-100">Kayıt Ol</button>
        </form>

        <div class="text-center mt-4 extra-links">
            <p class="small mb-2">Zaten hesabınız var mı? <a href="/Account/Login">Giriş Yap</a></p>
            <a href="/Home/Index"><i class="fas fa-arrow-left me-1"></i> Ana Sayfaya Dön</a>
        </div>
    </div>

</body>

</html>